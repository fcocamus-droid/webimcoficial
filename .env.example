# ============================================================
# TEMPLATE DE VARIABLES DE ENTORNO
# Copiar a .env.local y completar con valores reales
# ============================================================

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# NextAuth v5 - generar con: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Resend (email transaccional) - obtener en resend.com
RESEND_API_KEY=""
RESEND_FROM="cotizador@imccargo.cl"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="IMC Cargo - Cotizador Internacional"
